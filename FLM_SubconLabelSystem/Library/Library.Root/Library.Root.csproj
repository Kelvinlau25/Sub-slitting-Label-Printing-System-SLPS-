  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Library.Common\Library.Common.csproj" />
    <ProjectReference Include="..\Library.Control.Base\Library.Control.Base.csproj" />
  </ItemGroup>

</Project>