@page
@model PFRLabelIssuing.Pages.MasterMaint.MM_PC1_DtlModel
@{
    ViewData["PageTitle"] = Model.PageTitle;
}
<partial name="_Title" />
<partial name="_Error" />

@if (Model.Action == BasePageModel.EnumAction.View || Model.Action == BasePageModel.EnumAction.Delete)
{
    <table class="detailinfo">
        <tr>
            <td style="width:180px;">PC1</td>
            <td> : </td>
            <td>@Model.DisplayPC1</td>
        </tr>
        <tr>
            <td>Description</td>
            <td> : </td>
            <td>@Model.DisplayDescription</td>
        </tr>
        <tr>
            <td>Created By</td>
            <td> : </td>
            <td>@Model.CreatedBy</td>
        </tr>
        <tr>
            <td>Created Date</td>
            <td> : </td>
            <td>@(Model.CreatedDate.HasValue ? Model.CreatedDate.Value.ToString("dd/MM/yyyy HH:mm:ss") : "")</td>
        </tr>
        <tr>
            <td>Updated By</td>
            <td> : </td>
            <td>@Model.UpdatedBy</td>
        </tr>
        <tr>
            <td>Updated Date</td>
            <td> : </td>
            <td>@(Model.UpdatedDate.HasValue ? Model.UpdatedDate.Value.ToString("dd/MM/yyyy HH:mm:ss") : "")</td>
        </tr>
    </table>
}

@if (Model.Action == BasePageModel.EnumAction.Add || Model.Action == BasePageModel.EnumAction.Edit)
{
    <form method="post">
        <table class="detailinfo">
            <tr>
                <td><span class="text-danger">*</span></td>
                <td style="width:180px;">PC1</td>
                <td> : </td>
                <td>
                    @if (Model.Action == BasePageModel.EnumAction.Edit)
                    {
                        <span>@Model.PC1</span>
                        <input type="hidden" asp-for="PC1" />
                    }
                    else
                    {
                        <input type="text" asp-for="PC1" style="width:200px;" maxlength="6" />
                    }
                    <span asp-validation-for="PC1" class="text-danger"></span>
                </td>
            </tr>
            <tr>
                <td><span class="text-danger">*</span></td>
                <td>Description</td>
                <td> : </td>
                <td>
                    <input type="text" asp-for="Description" style="width:300px;" maxlength="50" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </td>
            </tr>
        </table>
        <partial name="_Controller" />
    </form>
}

@if (Model.Action == BasePageModel.EnumAction.View || Model.Action == BasePageModel.EnumAction.Delete)
{
    <partial name="_Controller" />
}

@if (!string.IsNullOrEmpty(Model.StartupScript))
{
    <script>@Html.Raw(Model.StartupScript)</script>
}
