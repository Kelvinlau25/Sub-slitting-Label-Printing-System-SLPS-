@page
@model PFRLabelIssuing.Pages.MasterMaint.MM_PC1Model
@{
    ViewData["PageTitle"] = Model.PageTitle;
}
<partial name="_Title" />
<partial name="_Search" />
@{
    ViewData["ShowAdd"] = Model.AddControl;
    ViewData["AddUrl"] = Model.GetUrl(BasePageModel.EnumAction.Add);
    ViewData["ShowPrint"] = Model.PrintControl;
}
<partial name="_GridHeader" />
<table width="100%">
<tr><td>
    <table width="100%" class="table">
        <thead class="title_bar">
            <tr>
                @if (Model.DeleteControl)
                {
                    <th style="width:30px; text-align:center; vertical-align:middle;"></th>
                }
                <th style="width:10%; text-align:left; vertical-align:middle;">PC1</th>
                <th style="width:60%; text-align:left; vertical-align:middle;">Description</th>
                <th style="width:15%; text-align:center; vertical-align:middle;">Record Type</th>
                @if (Model.ViewHistoryControl)
                {
                    <th style="width:80px; text-align:center; vertical-align:middle;">Audit Trail</th>
                }
            </tr>
        </thead>
        <tbody>
        @if (Model.GridData != null && Model.GridData.Rows.Count > 0)
        {
            @foreach (DataRow row in Model.GridData.Rows)
            {
                <tr onmouseover="Highlight(this)" onmouseout="UnHighlight(this)">
                    @if (Model.DeleteControl)
                    {
                        <td style="text-align:center; vertical-align:middle;">
                            <a target="_self" href="@Model.GetUrl(BasePageModel.EnumAction.Delete, row["ID_MM_PC1"].ToString())"><img src="@Url.Content("~/image/delete1.gif")" alt="Delete" /></a>
                        </td>
                    }
                    <td style="text-align:left; vertical-align:middle;">
                        <a href="@Model.GetUrl(BasePageModel.EnumAction.View, row["ID_MM_PC1"].ToString())">@row["PC1"]</a>
                    </td>
                    <td style="text-align:left; vertical-align:middle;">@row["DESCRIPTION"].ToString().ToUpper()</td>
                    <td style="text-align:center; vertical-align:middle;">@row["REC_TYPE"]</td>
                    @if (Model.ViewHistoryControl)
                    {
                        <td style="text-align:center; vertical-align:middle;">
                            <a target="_blank" href="@Model.GetUrl(BasePageModel.EnumAction.History, row["ID_MM_PC1"].ToString())">View</a>
                        </td>
                    }
                </tr>
            }
        }
        else
        {
            <tr><td colspan="@(3 + (Model.DeleteControl ? 1 : 0) + (Model.ViewHistoryControl ? 1 : 0))" class="text-center text-danger fw-bold">Record Not Found</td></tr>
        }
        </tbody>
    </table>
</td></tr>
</table>
@{
    ViewData["TotalRecords"] = Model.TotalRecords;
    ViewData["TotalPages"] = Model.TotalPages;
    ViewData["CurrentPage"] = Model.PageNo;
    ViewData["BaseListUrl"] = Model.GenerateList;
}
<partial name="_GridFooter" />
