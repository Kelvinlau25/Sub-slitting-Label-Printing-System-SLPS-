@page
@model PFRLabelIssuing.Pages.PopUp.PP_PC2SUBModel
@{
    Layout = "_MainLayout";
    ViewData["Title"] = "PC2 Popup";
}

<script type="text/javascript">
    function passvalue(pc2mother, lblpc2mother) {
        var opener = window.opener;
        if (!opener) { alert('Parent window not found.'); return; }
        if ('@Model.Pc2mother' == 'pc2mother') {
            var motherInput = opener.document.querySelector('.pc2mother');
            if (motherInput) motherInput.value = pc2mother;
            var btn = opener.document.querySelector('.btnpc2');
            if (btn) btn.click();
        } else {
            var idx = parseInt('@Model.Pc2mother') - 1;
            var inputs = opener.document.querySelectorAll('[data-child-pc2]');
            if (inputs.length > idx && idx >= 0) {
                inputs[idx].value = pc2mother;
            }
            var btnChild = opener.document.querySelector('.btnpc2child');
            if (btnChild) btnChild.click();
        }
        window.close();
    }
</script>

<partial name="_Title" />
<h3>@Model.SubTitle</h3>
<partial name="_Search" />

<table width="100%">
<tr><td>
    <table width="100%" class="table">
        <thead class="title_bar">
            <tr>
                <th style="width:30%; text-align:center; vertical-align:middle;">Product Code 2</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.GridData != null && Model.GridData.Rows.Count > 0)
        {
            @foreach (System.Data.DataRow row in Model.GridData.Rows)
            {
                <tr>
                    <td style="text-align:center; vertical-align:middle;">
                        <a href="#" onclick="passvalue('@row["PC2"]','@row["ID_MM_PC2"]'); return false;">@row["PC2"]</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td class="text-center text-danger fw-bold">Record Not Found</td></tr>
        }
        </tbody>
    </table>
</td></tr>
</table>

@{
    ViewData["TotalRecords"] = Model.TotalRecords;
    ViewData["TotalPages"] = Model.TotalPages;
    ViewData["CurrentPage"] = Model.PageNo;
    ViewData["BaseListUrl"] = Model.GenerateList;
}
<partial name="_GridFooter" />
