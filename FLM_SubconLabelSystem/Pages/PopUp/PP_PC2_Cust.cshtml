@page
@model PFRLabelIssuing.Pages.PopUp.PP_PC2_CustModel
@{
    Layout = "_MainLayout";
    ViewData["Title"] = "PC2 Customer Popup";
}

<script type="text/javascript">
    function passvalue(pc2cust, lblpc2cust) {
        window.opener.$('.@Model.Pc2cust').val(pc2cust);
        window.opener.$('.@Model.Lblpc2cust').val(lblpc2cust);
        window.opener.document.getElementById('@Model.StrHdnPC2Customer').value = pc2cust;
        window.opener.document.getElementById('@Model.StrHdnUnitWeightCustomer').value = lblpc2cust;
        window.opener.document.getElementById('@Model.StrBtnName').click();
        window.close();
    }
</script>

<partial name="_Title" />
<partial name="_Search" />

<table width="100%">
<tr><td>
    <table width="100%" class="table">
        <thead class="title_bar">
            <tr>
                <th style="width:30%; text-align:center; vertical-align:middle;">Product Code 2 Customer</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.GridData != null && Model.GridData.Rows.Count > 0)
        {
            @foreach (System.Data.DataRow row in Model.GridData.Rows)
            {
                <tr>
                    <td style="text-align:center; vertical-align:middle;">
                        <a href="#" onclick="javascript:passvalue('@row["PC2"]','@row["UNIT_WEIGHT"]')">@row["PC2"]</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td class="text-center text-danger fw-bold">Record Not Found</td></tr>
        }
        </tbody>
    </table>
</td></tr>
</table>

@{
    ViewData["TotalRecords"] = Model.TotalRecords;
    ViewData["TotalPages"] = Model.TotalPages;
    ViewData["CurrentPage"] = Model.PageNo;
    ViewData["BaseListUrl"] = Model.GenerateList;
}
<partial name="_GridFooter" />
