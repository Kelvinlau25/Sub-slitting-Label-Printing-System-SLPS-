@page
@model PFRLabelIssuing.Pages.Transactions.SUBSLIT_REQ_Model
@{
    Layout = "_MainLayout";
    ViewData["Title"] = "Sub Slitting Request";
}

<link href="@Url.Content("~/css/jquery-ui.css")" rel="stylesheet" type="text/css" />

<style type="text/css">
    .ui-datepicker-trigger { display: inline; }
    .style2 { width: 130px; }
    .style3 { width: 10px; }
    .style4 { width: 280px; }
    .style12 { height: 30px; }
    .bin { background-image: url("paper.gif"); }
</style>

<script type="text/javascript">
    $(document).ready(function () {
        $("#txtRefNo").change(function () {
            var x = $(this).val();
            if (x.includes("&")) {
                alert("The character & cannot be used in Ref No. Please replace it with a different value.");
            }
        });
    });

    $(function () {
        $(".txtDate").datepicker({
            showOn: 'button', buttonImageOnly: true,
            buttonImage: '@Url.Content("~/image/icon_cal.png")',
            numberOfMonths: 1, dateFormat: 'dd/mm/yy'
        });
        $(".txtETD").datepicker({
            showOn: 'button', buttonImageOnly: true,
            buttonImage: '@Url.Content("~/image/icon_cal.png")',
            numberOfMonths: 1, dateFormat: 'dd/mm/yy',
            onSelect: function (selected) { $(".txtETA").datepicker("option", "minDate", selected); }
        });
        $(".txtETA").datepicker({
            showOn: 'button', buttonImageOnly: true,
            buttonImage: '@Url.Content("~/image/icon_cal.png")',
            numberOfMonths: 1, minDate: 0, dateFormat: 'dd/mm/yy',
            onSelect: function (selected) { $(".txtETD").datepicker("option", selected); }
        });
        $(".no_type").keydown(function () { return false; });

        var lbl = [@Html.Raw(string.Join(", ", Model.ProdLineAutoComplete))];
        $(".prod").autocomplete({ source: lbl });

        var lbl2 = [@Html.Raw(string.Join(", ", Model.PC1AutoComplete))];
        $(".pc1").autocomplete({ source: lbl2 });

        var lbl3 = [@Html.Raw(string.Join(", ", Model.PC2AutoComplete))];
        $(".pc2").autocomplete({
            source: lbl3,
            select: function (event, ui) {
                event.preventDefault();
                $('.pc2').val(ui.item.value);
                document.getElementById('btnCalc').click();
            }
        });

        var lblchild = [@Html.Raw(string.Join(", ", Model.PC1ChildAutoComplete))];
        $(".pcchild1").autocomplete({ source: lblchild });

        var lblchild2 = [@Html.Raw(string.Join(", ", Model.PC2ChildAutoComplete))];
        $(".pcchild2").autocomplete({
            source: lblchild2,
            select: function (event, ui) {
                event.preventDefault();
                $(this).val(ui.item.value);
                document.getElementById('btnChildCalc').click();
            }
        });
    });

    function popupwindow(pc2mother, lblpc2mother) {
        window.open('@Url.Content("~/PopUp/PP_PC2SUB")?itm1=' + pc2mother + '&itm2=' + lblpc2mother + '&itm3=',
            'PopUp', 'directories=no,titlebar=no,toolbar=no,location=no,status=no,menubar=no,scrollbars=yes,resizable=no,width=800,height=600');
    }

    function showDialogue(v) {
        document.getElementById("dialog-msg").innerHTML = "Do you want to proceed to save for Sub Slitting Waste is " + v + " value?";
        $("#dialog-confirm").dialog({
            resizable: false, height: 170, width: 400, modal: true,
            buttons: {
                "Yes": function () {
                    document.getElementById('inpHide').value = "1";
                    $(this).dialog("close");
                    document.getElementById('btnConfirmSave').click();
                },
                "No": function () {
                    document.getElementById('inpHide').value = "0";
                    $(this).dialog("close");
                }
            }
        });
    }
</script>

<div id="dialog-confirm" title="" style="display:none;">
    <table>
        <tr>
            <td><img src='@Url.Content("~/image/warning-sign.png")' style="width:50px; height:50px;" /></td>
            <td><span id="dialog-msg"></span></td>
        </tr>
    </table>
</div>

<table width="100%" style="height:100%;" border="0" cellspacing="0" cellpadding="0">
    <tr><td><h3>Sub-Slitting Request Form - Add</h3></td></tr>
</table>
<br />

<form method="post">
    <input type="hidden" id="inpHide" name="InpHide" value="0" />

    <table width="100%" style="height:100%;" border="0">
        <tr>
            <td class="style2">To</td>
            <td class="style3">:</td>
            <td class="style4">
                <select asp-for="CompCodeValue" asp-items="Model.CompCodeItems"></select>
            </td>
            <td class="style2">Ref No</td>
            <td class="style3">:</td>
            <td class="style4">
                <input type="text" asp-for="RefNo" id="txtRefNo" />
            </td>
        </tr>
        <tr>
            <td>Department</td><td>:</td><td>@Model.Department</td>
            <td>Date</td><td>:</td>
            <td><input type="text" asp-for="TransDate" class="txtDate" readonly="readonly" /></td>
        </tr>
        <tr>
            <td>By</td><td>:</td><td>@Model.ByUser</td>
            <td>Rev</td><td>:</td><td>@Model.RevisionCount</td>
        </tr>
        <tr>
            <td>Requestor Status</td><td>:</td><td>@Model.ReqStatus</td>
            <td>Vendor Status</td><td>:</td><td>@Model.VenStatus</td>
        </tr>
    </table>

    <br />

    @if (Model.ShowMotherPanel)
    {
    <table width="100%"><tr><td>SUB-SLIT MOTHER ROLL DESCRIPTION</td></tr></table>

    <table border="1" style="width:100%; border-collapse:collapse; border-color:Black;">
        <tr style="text-align:center; background-color:#bfd4ea;">
            <td style="width:2%">LINE</td>
            <td style="width:3%">PC1</td>
            <td style="width:10%">PC2</td>
            <td style="width:2%">QTY (ROLL)</td>
            <td style="width:2%">UNIT WEIGHT (KG)</td>
            <td style="width:2%">TOTAL WEIGHT (KG)</td>
            <td style="width:2%">SUB-SLIT WASTE (KG)</td>
            <td style="width:5%">ETD PFR</td>
            <td style="width:5%">ETA SUB-SLIT CONTRACTOR</td>
        </tr>
        <tr>
            <td><input type="text" asp-for="ProdLine" class="prod" style="width:94%;" /></td>
            <td><input type="text" asp-for="PC1Value" class="pc1" style="width:94%;" /></td>
            <td>
                <input type="text" asp-for="PC2Value" class="pc2mother no_type" style="width:85%;" />
                <input type="button" value="..." onclick="popupwindow('pc2mother','lblpc2mother');" />
                <button type="submit" id="btnCalc" asp-page-handler="Calculate" class="btnpc2" style="display:none">calc</button>
            </td>
            <td><input type="text" asp-for="Qty" style="width:90%;" /></td>
            <td style="text-align:right">@Model.UnitWeight</td>
            <td style="text-align:right">@Model.TotWeight</td>
            <td style="text-align:right">@Model.SubSlitWaste</td>
            <td><input type="text" asp-for="ETD" class="txtETD" style="width:80%;" readonly="readonly" /></td>
            <td><input type="text" asp-for="ETA" class="txtETA" style="width:80%;" readonly="readonly" /></td>
        </tr>
    </table>

    <table width="90%">
        <tr>
            <td width="10%" align="center"><button type="submit" asp-page-handler="Next">Next</button></td>
            <td width="10%" align="center"><button type="submit" asp-page-handler="Reset">Reset</button></td>
            <td width="80%"></td>
        </tr>
    </table>
    <br />
    }

    <input type="hidden" asp-for="UnitWeight" />
    <input type="hidden" asp-for="TotWeight" />
    <input type="hidden" asp-for="SubSlitWaste" />
    <input type="hidden" asp-for="RevisionCount" />
    <input type="hidden" asp-for="ReqStatus" />
    <input type="hidden" asp-for="VenStatus" />
    <input type="hidden" asp-for="SeqMother" />
    <input type="hidden" asp-for="EditFlag" />

    @if (Model.ShowChildPanel)
    {
        <div>
            SUB-SLIT CUSTOMER ROLL DESCRIPTION
            <br />
            <button type="submit" id="btnChildCalc" asp-page-handler="ChildCalculate" class="btnpc2child" style="display:none">childcalc</button>

            <table width="100%" class="table">
                <thead class="title_bar">
                    <tr>
                        <th style="width:1%">DEL</th>
                        <th style="width:4%">PC1</th>
                        <th style="width:11%">PC2</th>
                        <th style="width:2%">QTY (ROLL)</th>
                        <th style="width:2%">UNIT WEIGHT (KG)</th>
                        <th style="width:2%">TOTAL WEIGHT (KG)</th>
                        <th style="width:10%">REMARK</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.ChildRows != null)
                {
                    for (int i = 0; i < Model.ChildRows.Count; i++)
                    {
                        var row = Model.ChildRows[i];
                        <tr>
                            <td style="text-align:center;">
                                <button type="submit" asp-page-handler="DeleteRow" name="deleteIndex" value="@i">
                                    <img src="@Url.Content("~/image/delete.gif")" />
                                </button>
                            </td>
                            <td><input type="text" name="ChildRows[@i].PC1Cust" value="@row.PC1Cust" class="pcchild1" style="width:95%;" /></td>
                            <td>
                                <input type="text" name="ChildRows[@i].PC2Cust" value="@row.PC2Cust" class="pcchild2 no_type" data-child-pc2="@i" style="width:85%;" />
                                <input type="button" value="..." onclick="popupwindow('@(i+1)','lblpc2mother');" />
                            </td>
                            <td><input type="text" name="ChildRows[@i].CQty" value="@row.CQty" style="width:95%;" /></td>
                            <td style="text-align:right;">@row.CWeight</td>
                            <td style="text-align:right;">@row.CTotalWeight</td>
                            <td><input type="text" name="ChildRows[@i].Remark" value="@row.Remark" style="width:97%;" /></td>
                            <input type="hidden" name="ChildRows[@i].CWeight" value="@row.CWeight" />
                            <input type="hidden" name="ChildRows[@i].CTotalWeight" value="@row.CTotalWeight" />
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center text-danger fw-bold">Record Not Found</td></tr>
                }
                </tbody>
            </table>

            <table border="0" width="90%">
                <tr>
                    <td align="center" width="20%"><button type="submit" asp-page-handler="AddRow">Add Row</button></td>
                    <td align="center" width="20%"><button type="submit" asp-page-handler="Save">Save</button></td>
                    <td width="60%"></td>
                </tr>
            </table>
        </div>
    }
    <br />

    @if (Model.ShowListPanel)
    {
        <div>
            <table width="100%" class="table">
                <thead class="title_bar">
                    <tr>
                        <th style="width:2%"></th>
                        <th style="text-align:center;">PRODUCTION LINE</th>
                        <th style="text-align:center;">PC1 MOTHER</th>
                        <th style="text-align:center;">PC2 MOTHER</th>
                        <th style="text-align:center;">QTY (ROLL)</th>
                        <th style="text-align:center;">UNIT WEIGHT (KG)</th>
                        <th style="text-align:center;">TOTAL WEIGHT (KG)</th>
                        <th style="text-align:center;">PC1 CUSTOMER</th>
                        <th style="text-align:center;">PC2 CUSTOMER</th>
                        <th style="text-align:center;">QTY (ROLL)</th>
                        <th style="text-align:center;">UNIT WEIGHT (KG)</th>
                        <th style="text-align:center;">TOTAL WEIGHT (KG)</th>
                        <th style="text-align:center;">SUB-SLIT WASTE (KG)</th>
                        <th style="text-align:center;">ETD PFR</th>
                        <th style="text-align:center;">ETA SUBSLIT CONTRACTOR</th>
                        <th style="text-align:center;">REMARK</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.ListData != null && Model.ListData.Rows.Count > 0)
                {
                    decimal totalMQty = 0, totalMTotalWeight = 0;
                    decimal totalCQty = 0, totalCTotalWeight = 0, totalSubSlitWaste = 0;

                    for (int i = 0; i < Model.ListData.Rows.Count; i++)
                    {
                        var row = Model.ListData.Rows[i];

                        if (decimal.TryParse(row["QTY"]?.ToString()?.Replace(",", ""), out decimal mq)) { totalMQty += mq; }
                        if (decimal.TryParse(row["M_TOTAL_WEIGHT"]?.ToString()?.Replace(",", ""), out decimal mtw)) { totalMTotalWeight += mtw; }
                        if (decimal.TryParse(row["C_QTY"]?.ToString()?.Replace(",", ""), out decimal cq)) { totalCQty += cq; }
                        if (decimal.TryParse(row["C_TOTAL_WEIGHT"]?.ToString()?.Replace(",", ""), out decimal ctw)) { totalCTotalWeight += ctw; }
                        if (decimal.TryParse(row["SUBSLIT_WASTE"]?.ToString()?.Replace(",", ""), out decimal sw)) { totalSubSlitWaste += sw; }

                        <tr>
                            <td style="text-align:center;">
                                @if (row["CHK"]?.ToString() == "1")
                                {
                                    <input type="radio" name="SelectedSeqMother" value="@row["SEQ"]|@row["PC2_MOTHER"]|@row["PC1_MOTHER"]|@row["PRODLINE_NO"]" />
                                }
                            </td>
                            <td style="text-align:center;">@row["PRODLINE_NO"]</td>
                            <td style="text-align:center;">@row["PC1_MOTHER"]</td>
                            <td style="text-align:center;">@row["PC2_MOTHER"]</td>
                            <td style="text-align:center;">@row["QTY"]</td>
                            <td style="text-align:center;">@row["M_WEIGHT"]</td>
                            <td style="text-align:center;">@row["M_TOTAL_WEIGHT"]</td>
                            <td style="text-align:center;">@row["PC1_CUST"]</td>
                            <td style="text-align:center;">@row["PC2_CUST"]</td>
                            <td style="text-align:center;">@row["C_QTY"]</td>
                            <td style="text-align:center;">@row["C_WEIGHT"]</td>
                            <td style="text-align:center;">@row["C_TOTAL_WEIGHT"]</td>
                            <td style="text-align:center;">@row["SUBSLIT_WASTE"]</td>
                            <td style="text-align:center;">@row["ETD"]</td>
                            <td style="text-align:center;">@row["ETA"]</td>
                            <td style="text-align:center;">@row["REMARK"]</td>
                        </tr>
                    }

                    <tr style="font-weight:bold;">
                        <td></td>
                        <td></td>
                        <td></td>
                        <td style="text-align:center;">Total</td>
                        <td style="text-align:center;">@totalMQty.ToString("#,###,###,##0.0")</td>
                        <td></td>
                        <td style="text-align:center;">@totalMTotalWeight.ToString("#,###,###,##0.0")</td>
                        <td></td>
                        <td></td>
                        <td style="text-align:center;">@totalCQty</td>
                        <td></td>
                        <td style="text-align:center;">@totalCTotalWeight.ToString("#,###,###,##0.0")</td>
                        <td style="text-align:center;">@totalSubSlitWaste.ToString("#,###,###,##0.0")</td>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>
                }
                else
                {
                    <tr><td colspan="16" class="text-center text-danger fw-bold">Record Not Found</td></tr>
                }
                </tbody>
            </table>

            <table width="90%">
                <tr>
                    <td width="10%" align="center">
                        <button type="submit" asp-page-handler="Edit">Edit</button>
                    </td>
                    <td width="10%" align="center">
                        <button type="submit" asp-page-handler="Delete"
                            onclick="return confirm('Are you sure to delete the selected PC2 Mother/Child records?');">Delete</button>
                    </td>
                    <td width="80%"></td>
                </tr>
            </table>
        </div>
    }

    <table width="90%">
        <tr>
            <td width="70%"></td>
            <td width="15%" align="center" class="style12">
                @if (Model.ShowSubmitCancel)
                {
                    <button type="submit" asp-page-handler="Submit" style="width:116px;">Submit</button>
                }
            </td>
            <td width="15%" align="center" class="style12">
                @if (Model.ShowSubmitCancel)
                {
                    <button type="submit" asp-page-handler="Cancel" style="width:116px;">Cancel</button>
                }
            </td>
        </tr>
    </table>

    <button type="submit" id="btnConfirmSave" asp-page-handler="ConfirmSave" style="display:none">ConfirmSave</button>
</form>

@if (!string.IsNullOrEmpty(Model.StartupScript))
{
    <script>@Html.Raw(Model.StartupScript)</script>
}
